# Line endings
* text=auto eol=lf

# Scripts
*.bash text linguist-language=Shell
*.sh   text linguist-language=Shell
*.zsh  text linguist-language=Shell

# Config & Workflow
*.json text linguist-language=JSON
*.toml text linguist-language=TOML
*.cff  text linguist-language=YAML
*.yaml text linguist-language=YAML
*.yml  text linguist-language=YAML

# Languages
*.cabal   text           linguist-language=Haskell
*.hs      text           linguist-language=Haskell
*.lhs     text           linguist-language=Haskell
*.lean    text           linguist-language=Lean
*.rs      text diff=rust linguist-language=Rust
*.hyp     text           linguist-language=Text
*.hypatia text           linguist-language=Text

# Textual Documents
*.md  text diff=markdown linguist-language=Markdown
*.tex text diff=tex      linguist-language=TeX
*.txt text               linguist-language=Text

# Textual Images
*.svg  text linguist-language=SVG

# Binary Documents
*.djv  binary
*.djvu binary
*.pdf  binary

# Binary Images
*.eps  binary
*.gif  binary
*.ico  binary
*.jpg  binary
*.jpeg binary
*.png  binary
*.webp binary

# Archives
*.7z    binary
*.bz2   binary
*.gz    binary
*.rar   binary
*.tar   binary
*.tgz   binary
*.xz    binary
*.zip   binary
